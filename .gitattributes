# Normalize line endings to LF for all text files
* text=auto eol=lf

# Force these to always be LF
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.php   text eol=lf
*.md    text eol=lf
*.env   text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.ico   binary
*.zip   binary
*.pdf   binary
